def shiro_favorite_subdir_change(img_dir, path_recorder, load_switch, img_path_browser, img_path_depth):
    outputs = change_dir_dropdown(img_dir, path_recorder, load_switch, img_path_browser, img_path_depth)
    img_path_value = outputs[5]
    next_sub, next_row = shiro_subdir_update(img_path_value)
    lower_sub, lower_row = shiro_subdir_reset()
    return (*outputs, next_sub, next_row, lower_sub, lower_row)

def shiro_favorite_subdir_change_level2(img_dir, path_recorder, load_switch, img_path_browser, img_path_depth):
